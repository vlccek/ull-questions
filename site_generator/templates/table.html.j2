{% extends "base_wide.html.j2" %}

{% block content %}
    <a href="index.html" class="btn btn-secondary my-4">Zpět na hlavní stránku</a>
    <h1 class="my-4">{{ title }}</h1>

    <div class="alert alert-info" role="alert">
        <strong>Vysvětlení sloupce "Trend (6 měs.)":</strong>
        Tento graf vizuálně zobrazuje dny, ve kterých se otázka objevila v testech za posledních 6 měsíců.
        Každý malý čtvereček reprezentuje jeden den.
        <span style="display: inline-block; width: 10px; height: 10px; background-color: #0d6efd; border-radius: 2px;"></span> - Otázka se v tento den vyskytla.
        <span style="display: inline-block; width: 10px; height: 10px; background-color: #ebedf0; border-radius: 2px;"></span> - Otázka se v tento den nevyskytla.
        Měsíce jsou zobrazeny v pořadí od nejstaršího (vlevo) po nejnovější (vpravo).
    </div>

    <div class="table-responsive">
        <table id="questionsTable" class="table table-striped table-bordered" style="width:100%">
            <thead>
                <tr>
                    <th class="w-25">Otázka</th>
                    <th>Kategorie</th>
                    <th>Správná odpověď</th>
                    <th>Počet výskytů</th>
                    <th>Trend (6 měs.)</th>
                    <th>Naposledy viděno</th>
                    <th>Detail</th>
                </tr>
            </thead>
            <tbody>
                {% for question in questions %}
                <tr>
                    <td>{{ question.question_text }}</td>
                    <td>
                        {% if question.kategorie %}
                            <span class="badge bg-info">{{ question.kategorie }}</span>
                        {% endif %}
                    </td>
                    {% set correct_answer_key = 'option_' + question.correct_option.lower() %}
                    <td>{{ question.options[correct_answer_key] }}</td>
                    <td>{{ question.occurrence_count }}</td>
                    <td>{{ question.heatmap_svg|safe }}</td>
                    <td>{{ question.last_seen }}</td>
                    <td><a href="questions/{{ question.hashid }}.html" class="btn btn-sm btn-outline-secondary">Zobrazit</a></td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}

{% block scripts %}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.js"></script>
    <script>
        $(document).ready(function() {
            $('#questionsTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/2.0.8/i18n/cs.json"
                },
                "order": [[ 2, "desc" ]] // Default sort by 'Počet výskytů' descending
            });
        });
    </script>
{% endblock %}
